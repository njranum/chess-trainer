# Copy to .env (gitignored) and fill in. Every environment-specific value
# the app reads lives here — nothing is hard-coded.

# --- Django ---
DJANGO_SECRET_KEY=            # required in prod; any long random string
DJANGO_DEBUG=1                # 0 in prod
DJANGO_ALLOWED_HOSTS=         # comma-separated, e.g. chess.example.com
# DJANGO_STATIC_ROOT=         # prod only; where collectstatic writes

# --- Database ---
# Leave unset for SQLite (dev). Postgres (prod):
# DATABASE_URL=postgresql://user:password@localhost:5432/chess

# --- Pipeline ---
STOCKFISH_PATH=               # absolute path to the stockfish binary
CHESSCOM_USERNAME=            # whose games to ingest

# --- LLM tagging (optional — app is complete without it) ---
# CLAUDE_CODE_OAUTH_TOKEN=    # from `claude setup-token`, or use API auth
